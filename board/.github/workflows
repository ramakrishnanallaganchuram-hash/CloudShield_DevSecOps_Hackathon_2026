name: CloudShield DevSecOps Pipeline

on:
push:
branches:
- master
workflow_dispatch:

jobs:
ci-cd:
runs-on: ubuntu-latest

```
steps:

  # Checkout Code
  - name: Checkout Source Code
    uses: actions/checkout@v4

  # Setup Java
  - name: Setup Java
    uses: actions/setup-java@v4
    with:
      distribution: temurin
      java-version: '17'

  # Build Application
  - name: Build Maven Project
    run: mvn clean package -DskipTests

  # Upload Build Artifact
  - name: Upload WAR Artifact
    uses: actions/upload-artifact@v4
    with:
      name: cloudshield-war
      path: target/*.war

  # SonarQube Scan
  - name: SonarQube Code Scan
    run: |
      mvn clean verify sonar:sonar \
        -Dsonar.projectKey=CloudShield_DevSecOps_Hackathon_2026 \
        -Dsonar.host.url=${{ secrets.SONAR_HOST_URL }} \
        -Dsonar.login=${{ secrets.SONAR_TOKEN }}

  # Configure AWS Credentials
  - name: Configure AWS
    uses: aws-actions/configure-aws-credentials@v4
    with:
      aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
      aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
      aws-region: ${{ secrets.AWS_REGION }}

  # Login to ECR
  - name: Login to Amazon ECR
    uses: aws-actions/amazon-ecr-login@v2

  # Trivy Filesystem Scan
  - name: Trivy FS Scan
    uses: aquasecurity/trivy-action@master
    with:
      scan-type: fs
      scan-ref: .
      severity: HIGH,CRITICAL

  # Build Docker Image
  - name: Build Docker Image
    run: |
      IMAGE_TAG=$(date +%s)
      echo "IMAGE_TAG=$IMAGE_TAG" >> $GITHUB_ENV
      docker build -t ${{ secrets.ECR_REPOSITORY }}:$IMAGE_TAG .

  # Tag Docker Image
  - name: Tag Docker Image
    run: |
      ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
      docker tag ${{ secrets.ECR_REPOSITORY }}:${{ env.IMAGE_TAG }} \
      $ACCOUNT_ID.dkr.ecr.${{ secrets.AWS_REGION }}.amazonaws.com/${{ secrets.ECR_REPOSITORY }}:${{ env.IMAGE_TAG }}

  # Trivy Image Scan
  - name: Trivy Image Scan
    uses: aquasecurity/trivy-action@master
    with:
      scan-type: image
      image-ref: ${{ secrets.ECR_REPOSITORY }}:${{ env.IMAGE_TAG }}
      severity: HIGH,CRITICAL

  # Push Image to ECR
  - name: Push Image to ECR
    run: |
      ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
      docker push $ACCOUNT_ID.dkr.ecr.${{ secrets.AWS_REGION }}.amazonaws.com/${{ secrets.ECR_REPOSITORY }}:${{ env.IMAGE_TAG }}

  # Configure kubectl for EKS
  - name: Update kubeconfig
    run: |
      aws eks update-kubeconfig \
      --name ${{ secrets.EKS_CLUSTER_NAME }} \
      --region ${{ secrets.AWS_REGION }}

  # Deploy Kubernetes Resources
  - name: Deploy Kubernetes Manifests
    run: |
      kubectl apply -f k8s/namespace.yaml
      kubectl apply -f k8s/deployment.yaml -n ${{ secrets.K8S_NAMESPACE }}
      kubectl apply -f k8s/service.yaml -n ${{ secrets.K8S_NAMESPACE }}

  # Update Deployment Image
  - name: Update Kubernetes Deployment
    run: |
      ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)

      kubectl set image deployment/cloudshield-deployment \
      cloudshield-container=$ACCOUNT_ID.dkr.ecr.${{ secrets.AWS_REGION }}.amazonaws.com/${{ secrets.ECR_REPOSITORY }}:${{ env.IMAGE_TAG }} \
      -n ${{ secrets.K8S_NAMESPACE }}

      kubectl rollout status deployment/cloudshield-deployment \
      -n ${{ secrets.K8S_NAMESPACE }} --timeout=200s
